<service>
  <id>jenkins</id>
  <name>Jenkins8080agent</name>
  <description>This service runs Jenkins agent</description>
  <executable>C:\Program Files\Common Files\Oracle\Java\javapath\java.exe</executable>
  <arguments>-jar C:\www\jenkins\agent.jar -jnlpUrl JENKINS_URL_WITH_YOUR_PATH -secret YOUR_SECRET -workDir "C:\www\jenkins"</arguments>
  <log mode="roll" />
  <onfailure action="restart" />
</service>